<mujoco model="g1_29dof on tilting platform">
  <include file="g1_29dof.xml"/>

  <statistic center="0 0 0.5" extent="2.0"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="platform_top" rgba="0.2 0.5 0.8 1" reflectance="0.05"/>
    <material name="platform_side" rgba="0.15 0.35 0.55 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 2.5" dir="0 0 -1" directional="true"/>
    <!-- Catch-all ground (well below the platform, so the robot can fall off safely). -->
    <geom name="floor" pos="0 0 -2" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Dual-axis tilting platform centered at the origin.
         Plate top surface ends at z=0 so the existing G1 keyframe (pelvis z=0.793)
         drops onto it without modifying the robot XML. -->
    <body name="platform_pitch_body" pos="0 0 -0.02">
      <joint name="platform_pitch" type="hinge" axis="1 0 0" pos="0 0 0" damping="20" limited="false"/>
      <inertial pos="0 0 0" mass="0.5" diaginertia="0.05 0.05 0.05"/>
      <body name="platform_roll_body" pos="0 0 0">
        <joint name="platform_roll" type="hinge" axis="0 1 0" pos="0 0 0" damping="20" limited="false"/>
        <inertial pos="0 0 0" mass="0.5" diaginertia="0.05 0.05 0.05"/>
        <!-- The plate the robot stands on. Friction tuned so the feet grip. -->
        <geom name="platform_top" type="box" size="1.0 1.0 0.02" material="platform_top"
              friction="1.2 0.05 0.001" density="200"/>
        <!-- Visual rim to make the plate easier to read at a glance. -->
        <geom name="platform_rim_n" type="box" pos="0  1.0 0.02" size="1.0 0.01 0.02" material="platform_side" contype="0" conaffinity="0"/>
        <geom name="platform_rim_s" type="box" pos="0 -1.0 0.02" size="1.0 0.01 0.02" material="platform_side" contype="0" conaffinity="0"/>
        <geom name="platform_rim_e" type="box" pos=" 1.0 0 0.02" size="0.01 1.0 0.02" material="platform_side" contype="0" conaffinity="0"/>
        <geom name="platform_rim_w" type="box" pos="-1.0 0 0.02" size="0.01 1.0 0.02" material="platform_side" contype="0" conaffinity="0"/>
      </body>
    </body>
  </worldbody>

  <!-- State sensors for the platform — joint angle and rate, used by PlatformController
       to feed back actual state on rt/platform_state. -->
  <sensor>
    <jointpos name="platform_pitch_pos" joint="platform_pitch"/>
    <jointpos name="platform_roll_pos"  joint="platform_roll"/>
    <jointvel name="platform_pitch_vel" joint="platform_pitch"/>
    <jointvel name="platform_roll_vel"  joint="platform_roll"/>
  </sensor>
</mujoco>
