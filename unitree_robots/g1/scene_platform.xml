<mujoco model="g1_29dof on tilting platform">
  <include file="g1_29dof.xml"/>

  <statistic center="0 0 0.5" extent="2.0"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="platform_top" rgba="0.2 0.5 0.8 1" reflectance="0.05"/>
    <material name="platform_side" rgba="0.15 0.35 0.55 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 2.5" dir="0 0 -1" directional="true"/>
    <!-- Catch-all ground (well below the platform, so the robot can fall off safely). -->
    <geom name="floor" pos="0 0 -2" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Tilting platform as a MOCAP body — its world position/orientation is
         set directly each step by PlatformController via data->mocap_pos /
         mocap_quat. Mocap bodies don't participate in dynamics, so the boat
         motion is exactly what we command, independent of the robot's weight
         or movement on top. Contacts with the robot work normally.
         The plate's top surface is at z=0 in the body frame so the G1 keyframe
         (pelvis z=0.793) lands on it. -->
    <body name="platform" mocap="true" pos="0 0 -0.05">
      <!-- 10 cm thick plate so the G1's foot mesh (which extends ~5 cm below
           the ankle_roll_link origin while the actual collision spheres are
           at -3 cm) is visually contained inside the plate. -->
      <geom name="platform_top" type="box" size="1.0 1.0 0.05" material="platform_top"
            friction="1.2 0.05 0.001"/>
      <!-- Visual rims (no collision) so the edges of the plate are easy to read. -->
      <geom name="platform_rim_n" type="box" pos="0  1.0 0.05" size="1.0 0.01 0.02" material="platform_side" contype="0" conaffinity="0"/>
      <geom name="platform_rim_s" type="box" pos="0 -1.0 0.05" size="1.0 0.01 0.02" material="platform_side" contype="0" conaffinity="0"/>
      <geom name="platform_rim_e" type="box" pos=" 1.0 0 0.05" size="0.01 1.0 0.02" material="platform_side" contype="0" conaffinity="0"/>
      <geom name="platform_rim_w" type="box" pos="-1.0 0 0.05" size="0.01 1.0 0.02" material="platform_side" contype="0" conaffinity="0"/>
    </body>
  </worldbody>

  <!-- Initial pose: the G1 is pre-placed in the FixStand joint configuration
       (same target qs that the controller commands), so during the controller's
       ~5 s boot the robot doesn't collapse limp onto the plate before FixStand
       engages. With the platform now mocap, qpos has only 7 free-joint slots
       + 29 G1 motor joints = 36 entries (no more 2 platform hinges). -->
  <keyframe>
    <key name="fixstand"
         qpos="0 0 0.793  1 0 0 0
               -0.1 0 0 0.3 -0.2 0
               -0.1 0 0 0.3 -0.2 0
               0 0 0
               0.35  0.18 0 0.87 0 0 0
               0.35 -0.18 0 0.87 0 0 0"/>
  </keyframe>
</mujoco>
